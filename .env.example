# =====================================================
# Virunga WebGIS — Variables d'environnement (exemple)
# =====================================================
# Copier ce fichier en .env dans backend/ (et adapter pour frontend/.env.local)

# ----- GeoServer existant -----
GEOSERVER_URL=https://gis.virunga.org/geoserver
GEOSERVER_ADMIN_USER=your_admin_user
GEOSERVER_ADMIN_PASSWORD=your_admin_password

# ----- Catalogue public -----
CATALOG_SOURCE=hybrid
CATALOG_REFRESH_CRON=*/15 * * * *

# ----- Application -----
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://virunga.example.org
CORS_ORIGINS=https://virunga.example.org

# ----- Sécurité -----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ----- Logs -----
LOG_LEVEL=info
