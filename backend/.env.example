# Virunga WebGIS — Backend
# Copier vers backend/.env : npm run setup

GEOSERVER_URL=https://gis.virunga.org/geoserver

# Catalogue GeoServer (sync automatique)
GEOSERVER_ADMIN_USER=
GEOSERVER_ADMIN_PASSWORD=
CATALOG_SOURCE=hybrid
CATALOG_REFRESH_CRON=*/15 * * * *

# Développement local (production : NODE_ENV=production, URLs https://…)
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
LOG_LEVEL=info
