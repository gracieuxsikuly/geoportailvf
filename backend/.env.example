# =====================================================
# Virunga WebGIS Backend - Variables d'environnement
# =====================================================

GEOSERVER_URL=https://gis.virunga.org/geoserver
GEOSERVER_ADMIN_USER=your_admin_user
GEOSERVER_ADMIN_PASSWORD=your_admin_password

CATALOG_SOURCE=hybrid
CATALOG_REFRESH_CRON=*/15 * * * *

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://virunga.example.org
CORS_ORIGINS=https://virunga.example.org

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
LOG_LEVEL=info
